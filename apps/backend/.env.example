# Backend-Konfiguration fuer lokale Entwicklung und Deployments.
# Echte Secrets gehoeren nur in apps/backend/.env und duerfen nicht committed werden.
# Die lokale SQLite-Datei wird fest unter apps/backend/data/hwm.sqlite angelegt.

HWM_DEBUG_MODE=0
HWM_LOCAL_DEV=1

# Optionaler Kontakt-/Mailversand
CONTACT_SMTP_HOST=<smtp-host>
CONTACT_SMTP_USER=<smtp-user>
CONTACT_SMTP_PASSWORD=<smtp-password>
CONTACT_RECIPIENT=<support@example.com>
CONTACT_FROM_ADDRESS=Homework Manager <noreply@example.com>

# Logging
# Ohne Override schreibt das Backend nach apps/backend/logs/hwm-backend.log.
HWM_LOG_FILE=
HWM_LOG_MAX_BYTES=2097152
HWM_LOG_BACKUP_COUNT=5
HWM_LOG_DEFAULT_LINES=500
HWM_LOG_MAX_LINES=5000

# Auth / Rate Limits
LOGIN_RATE_LIMIT_WINDOW=300
LOGIN_RATE_LIMIT_MAX=10
VERIFY_RATE_LIMIT_WINDOW=3600
VERIFY_RATE_LIMIT_MAX=5
PASSWORD_RESET_REQUEST_WINDOW=3600
PASSWORD_RESET_REQUEST_MAX=5
PASSWORD_RESET_VERIFY_WINDOW=3600
PASSWORD_RESET_VERIFY_MAX=10
PASSWORD_RESET_CODE_LIFETIME_SECONDS=900
PASSWORD_RESET_CODE_LENGTH=8
PASSWORD_RESET_SUBJECT=Passwort zuruecksetzen

# Links/API-Keys
PRIMARY_TEST_BASE_URL=https://hwm-beta.akzuwo.ch
EMAIL_VERIFICATION_LINK_BASE=https://hwm-beta.akzuwo.ch
GROQ_API_KEY=
OPENAI_API_KEY=
